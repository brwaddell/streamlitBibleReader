SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Leonardo.ai (required for Image Processor)
LEONARDO_API_KEY=
# Recommended for children's book illustrations with Character/Style/Content Reference controlnets:
# LEONARDO_MODEL_ID=de7d3faf-762f-48e0-b3b7-9d0ac3a3fcf3  # Phoenix 1.0
# Optional override — default modelId lives in leonardo_series_config.py (LEONARDO_GENERATION_DEFAULTS)
# LEONARDO_MODEL_ID=
# Controlnet preprocessors: legacy SD uses style 67 / character 133 / location 100; Phoenix uses 166 / 397 / 364
# LEONARDO_CHARACTER_PREPROCESSOR_ID=133
# LEONARDO_PHOENIX_STYLE_PREPROCESSOR_ID=166
# LEONARDO_PHOENIX_CHARACTER_PREPROCESSOR_ID=397
# LEONARDO_PHOENIX_CONTENT_PREPROCESSOR_ID=364
# Phoenix contrast when UI not used (snap to 3 / 3.5 / 4): default 3 (gentler)
# LEONARDO_PHOENIX_CONTRAST=3
# Controlnet strength: Low, Mid, or High
# LEONARDO_STYLE_CONTROLNET_STRENGTH=High  # style/character reference previews
# LEONARDO_STYLE_CONTROLNET_SCENE_STRENGTH=Low  # per-block scene images (default Low)
# LEONARDO_CHARACTER_CONTROLNET_STRENGTH=Low
# LEONARDO_LOCATION_CONTROLNET_STRENGTH=Low
# Optional: soft spend guard for batch pipeline (stops gracefully before Leonardo hard cap)
# LEONARDO_BATCH_BUDGET_USD=150
# Output dimensions (32–1536, multiple of 8; default 800 matches app WebP max). UI pick overrides square preset only.
# LEONARDO_WIDTH=800
# LEONARDO_HEIGHT=800

ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID_MALE=bV9ai9Wem8olqrkR49Zw
ELEVENLABS_VOICE_ID_FEMALE=jqcCZkN6Knx8BJ5TBdYR

# Cloudflare R2 (images + audio storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_IMAGES=storybook-images
R2_BUCKET_AUDIO=storybook-audio
R2_PUBLIC_URL_IMAGES=https://image.aptreelearning.com
R2_PUBLIC_URL_AUDIO=https://audio.aptreelearning.com
